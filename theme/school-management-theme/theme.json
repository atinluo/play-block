{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "contentSize": "700px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px","em","rem","vh","vw","%"]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', 'Liberation Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
          "name": "System UI",
          "slug": "system-ui"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-ui)",
      "lineHeight": "1.6"
    }
  },
  "customTemplates": [
    {
      "name": "template-fullwidth",
      "title": "Full Width (S.M.S Compatible)",
      "postTypes": ["page"]
    }
  ]
}
